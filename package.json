{
  "name": "betagent",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "prisma:generate": "turbo run prisma:generate",
    "check": "biome check .",
    "db:migrate": "pnpm --filter @repo/api exec prisma migrate dev",
    "db:seed": "pnpm --filter @repo/api exec prisma db seed",
    "db:deploy": "pnpm --filter @repo/api exec prisma migrate deploy",
    "codegen": "echo \"GraphQL codegen not configured yet; point @graphql-codegen at services/api/graphql-schema.generated.gql\""
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "pnpm": "10.10.0",
    "turbo": "^2.5.3",
    "typescript": "^5.8.3"
  }
}
