# Shared / API
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/betagent

# JWT Supabase — use JWT secret from Supabase project Settings > API (“JWT Secret” legacy), not the anon/service role keys
SUPABASE_JWT_SECRET=

# Optional — only if validating issuer strictly (recommended for prod)
SUPABASE_JWT_ISSUER=https://YOUR_PROJECT.supabase.co/auth/v1

# CORS
WEB_ORIGIN=http://localhost:3000

# apps/web — copy to apps/web/.env.local for Next (prefix NEXT_PUBLIC exposes to browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
